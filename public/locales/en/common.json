      "mobilität": {
        "title": "1. Mobility",
        "description": "Ability to move independently",
        "questions": {
          "q1": {
            "text": "Can the person move independently in the living space?",
            "help": "Includes: Getting up, walking, using chair, leaving bed"
          },
          "q2": {
            "text": "Can the person climb stairs?",
            "help": "With or without aids such as stairlift"
          },
          "q3": {
            "text": "Does the person need help with transfers (bed/chair)?",
            "help": "Transfer includes: positioning, repositioning, help getting up"
          },
          "q4": {
            "text": "Does the person rely on mobility aids?",
            "help": "E.g. walker, walking frame, wheelchair"
          }
        }
      },
      "kognitiveLeistungen": {
        "title": "2. Cognitive Performance",
        "description": "Mental abilities and orientation",
        "questions": {
          "q1": {
            "text": "Is the person oriented in time, place and situation?",
            "help": "Can the person grasp date, location and current situation?"
          },
          "q2": {
            "text": "Are there problems remembering things?",
            "help": "Forgetfulness in daily life: medication, appointments, meal times"
          },
          "q3": {
            "text": "Can the person make decisions?",
            "help": "Ability to make everyday decisions independently"
          },
          "q4": {
            "text": "Are there behavioral abnormalities?",
            "help": "E.g. confusion, agitation, rejection of help"
          }
        }
      },
      "körperlichePflege": {
        "title": "3. Personal Care",
        "description": "Body hygiene and personal cleanliness",
        "questions": {
          "q1": {
            "text": "Can the person wash themselves?",
            "help": "Washing, showering, bathing – which body parts independently?"
          },
          "q2": {
            "text": "Can the person brush teeth and comb hair?",
            "help": "Oral hygiene and hair care"
          },
          "q3": {
            "text": "Can the person shave/apply makeup themselves?",
            "help": "Facial care, shaving, decorative makeup"
          },
          "q4": {
            "text": "Does the person need help using the toilet?",
            "help": "Bladder/bowel control, intimate care, incontinence care"
          }
        }
      },
      "behandlungspflege": {
        "title": "4. Medical Care",
        "description": "Medical care and treatment",
        "questions": {
          "q1": {
            "text": "Can the person take medication themselves?",
            "help": "Dosing, taking, monitoring medication intake"
          },
          "q2": {
            "text": "Can the person perform wound care alone?",
            "help": "Changing bandages, wound cleaning, applying ointments"
          },
          "q3": {
            "text": "Does the person need help with injections/medication?",
            "help": "Insulin, injections, eye drops, ear drops"
          },
          "q4": {
            "text": "Are there special treatments?",
            "help": "E.g. compression stockings, oxygen therapy, catheter"
          }
        }
      },
      "hauswirtschaftlicheVersorgung": {
        "title": "5. Household Management",
        "description": "Household management and meals",
        "questions": {
          "q1": {
            "text": "Can the person prepare meals?",
            "help": "Shopping, cooking, washing dishes, reheating"
          },
          "q2": {
            "text": "Can the person manage the household?",
            "help": "Cleaning, washing, ironing, waste disposal"
          },
          "q3": {
            "text": "Can the person do shopping?",
            "help": "Groceries, household items, medication"
          },
          "q4": {
            "text": "Can the person manage finances?",
            "help": "Paying bills, banking, mail"
          }
        }
      },
      "sozialeKontakte": {
        "title": "6. Social Contacts",
        "description": "Communication and participation in life",
        "questions": {
          "q1": {
            "text": "Can the person communicate actively?",
